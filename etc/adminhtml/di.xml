<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- ===================== Enablement gates (adminhtml) ===================== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Enablement\Form\AdminLogin" type="Hryvinskyi\InvisibleCaptcha\Model\Enablement\FormEnablement">
        <arguments><argument name="area" xsi:type="string">adminhtml</argument><argument name="form" xsi:type="string">admin_login</argument></arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Enablement\Form\AdminForgot" type="Hryvinskyi\InvisibleCaptcha\Model\Enablement\FormEnablement">
        <arguments><argument name="area" xsi:type="string">adminhtml</argument><argument name="form" xsi:type="string">admin_forgot</argument></arguments>
    </virtualType>

    <!-- ===================== Score thresholds (adminhtml) ==================== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\ScoreThreshold\Form\AdminLogin" type="Hryvinskyi\InvisibleCaptcha\Model\ScoreThreshold\FormScoreThreshold">
        <arguments><argument name="form" xsi:type="string">admin_login</argument></arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\ScoreThreshold\Form\AdminForgot" type="Hryvinskyi\InvisibleCaptcha\Model\ScoreThreshold\FormScoreThreshold">
        <arguments><argument name="form" xsi:type="string">admin_forgot</argument></arguments>
    </virtualType>

    <!-- ====================== Failure strategy (adminhtml) =================== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Form\AdminForgot"
                 type="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Redirect">
        <arguments>
            <argument name="redirectUrlProvider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Referer</argument>
        </arguments>
    </virtualType>

    <!-- ====================== Captcha descriptors (admin) =================== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Captcha\AdminLogin" type="Hryvinskyi\InvisibleCaptcha\Model\Captcha">
        <arguments>
            <argument name="action" xsi:type="string">admin_login</argument>
            <argument name="tokenStrategy" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Token\RequestParam</argument>
            <argument name="failureProvider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\AuthenticationException</argument>
            <argument name="enablement" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Enablement\Form\AdminLogin</argument>
            <argument name="scoreThreshold" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\ScoreThreshold\Form\AdminLogin</argument>
        </arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Captcha\AdminForgot" type="Hryvinskyi\InvisibleCaptcha\Model\Captcha">
        <arguments>
            <argument name="action" xsi:type="string">admin_forgot_password</argument>
            <argument name="tokenStrategy" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Token\RequestParam</argument>
            <argument name="failureProvider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Form\AdminForgot</argument>
            <argument name="enablement" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Enablement\Form\AdminForgot</argument>
            <argument name="scoreThreshold" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\ScoreThreshold\Form\AdminForgot</argument>
        </arguments>
    </virtualType>

    <!-- ====================== Form verify observers (admin) ================= -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Observer\Form\AdminLogin" type="Hryvinskyi\InvisibleCaptcha\Observer\FormVerify">
        <arguments><argument name="provider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Captcha\AdminLogin</argument></arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Observer\Form\AdminForgot" type="Hryvinskyi\InvisibleCaptcha\Observer\FormVerify">
        <arguments><argument name="provider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Captcha\AdminForgot</argument></arguments>
    </virtualType>

    <!-- ======================= Route-protection rule tester ================== -->
    <type name="Hryvinskyi\InvisibleCaptcha\Controller\Adminhtml\Tester\Run">
        <arguments>
            <argument name="logger" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Logger</argument>
        </arguments>
    </type>

    <!-- ============== Tag-list editors for route-protection bypasses ========= -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\ExcludedIpsTagList"
                 type="Hryvinskyi\ConfigurationFields\Block\Adminhtml\System\Config\Form\Field\TagList">
        <arguments>
            <argument name="tagListConfig" xsi:type="array">
                <item name="placeholder" xsi:type="string">203.0.113.10</item>
                <item name="validation" xsi:type="string">^(\d{1,3}(\.\d{1,3}){3}|[0-9A-Fa-f:]*:[0-9A-Fa-f:]*)$</item>
                <item name="validation_message" xsi:type="string">Enter a valid IPv4 or IPv6 address.</item>
                <item name="uppercase" xsi:type="boolean">false</item>
                <item name="separator" xsi:type="string">\n</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\ExcludedUserAgentsTagList"
                 type="Hryvinskyi\ConfigurationFields\Block\Adminhtml\System\Config\Form\Field\TagList">
        <arguments>
            <argument name="tagListConfig" xsi:type="array">
                <item name="placeholder" xsi:type="string">Googlebot</item>
                <!-- UA substrings may legitimately contain spaces, slashes and
                     punctuation — anything short of the newline separator. -->
                <item name="validation" xsi:type="string">^.+$</item>
                <item name="uppercase" xsi:type="boolean">false</item>
                <item name="separator" xsi:type="string">\n</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- ============= Tag-list editor for route-protection path lists ========= -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\RoutePathsTagList"
                 type="Hryvinskyi\ConfigurationFields\Block\Adminhtml\System\Config\Form\Field\TagList">
        <arguments>
            <argument name="tagListConfig" xsi:type="array">
                <item name="placeholder" xsi:type="string">customer/section/load</item>
                <item name="validation" xsi:type="string">^[^\s,]+$</item>
                <item name="validation_message" xsi:type="string">Path patterns cannot contain spaces or commas.</item>
                <item name="uppercase" xsi:type="boolean">false</item>
                <item name="separator" xsi:type="string">\n</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- ============= Tag-list editor for route-protection param lists ======== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\RouteParamsTagList"
                 type="Hryvinskyi\ConfigurationFields\Block\Adminhtml\System\Config\Form\Field\TagList">
        <arguments>
            <argument name="tagListConfig" xsi:type="array">
                <item name="placeholder" xsi:type="string">Type a parameter name and press Enter...</item>
                <item name="validation" xsi:type="string">^[A-Za-z0-9_.\[\]-]+$</item>
                <item name="validation_message" xsi:type="string">Only letters, digits and _ . [ ] - are allowed in a parameter name.</item>
                <item name="uppercase" xsi:type="boolean">false</item>
                <item name="separator" xsi:type="string">\n</item>
            </argument>
        </arguments>
    </virtualType>
</config>
