<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="controller_action_predispatch_adminhtml_auth_forgotpassword">
        <observer name="Hryvinskyi_InvisibleCaptcha::form_admin_forgot"
                  instance="Hryvinskyi\InvisibleCaptcha\Observer\Form\AdminForgot"/>
    </event>
    <event name="admin_user_authenticate_before">
        <observer name="Hryvinskyi_InvisibleCaptcha::form_admin_login"
                  instance="Hryvinskyi\InvisibleCaptcha\Observer\Form\AdminLogin"/>
    </event>
</config>
