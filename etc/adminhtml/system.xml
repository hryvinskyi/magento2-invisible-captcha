<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="hryvinskyi" translate="label" sortOrder="300">
            <label>Hryvinskyi Extensions</label>
        </tab>
        <section id="hryvinskyi_invisible_captcha" translate="label" type="text" sortOrder="100"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Invisible Captcha &amp; Bot Protection</label>
            <tab>hryvinskyi</tab>
            <resource>Hryvinskyi_InvisibleCaptcha::config</resource>

            <!-- ============================== General ============================== -->
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Master switch for captcha protection (form-level and route-level).</comment>
                </field>
                <field id="active_provider" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Active Provider</label>
                    <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\Provider</source_model>
                    <comment>The captcha provider used for form-level protection (and route gating unless overridden).</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="use_lazy_load" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Lazy Load Provider Script</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Load the provider API script after first form interaction (focus/blur/change).</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="disable_submit_form" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Disable Submit Until Ready</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Disable form submit until the captcha token is available.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="debug" translate="label comment" type="select" sortOrder="1000" showInDefault="1">
                    <label>Debug Logging</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Log verification and challenge events to var/log/invisible_captcha.log.</comment>
                </field>
            </group>

            <!-- ========================= Provider Credentials ===================== -->
            <!--
                Nested per-provider sub-groups produce the natural config paths
                hryvinskyi_invisible_captcha/providers/<code>/<field> read by ProviderConfig.
                (A flat <config_path> can't be used here — the schema restricts it to 3 segments.)
            -->
            <group id="providers" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Provider Credentials</label>
                <comment>Configure keys for each provider you intend to use. Generate reCAPTCHA keys at google.com/recaptcha/admin and Turnstile keys at dash.cloudflare.com.</comment>

                <group id="recaptcha_v3" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Google reCAPTCHA v3</label>
                    <field id="site_key" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1">
                        <label>Site Key</label>
                    </field>
                    <field id="secret_key" translate="label" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1">
                        <label>Secret Key</label>
                        <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    </field>
                    <field id="hide_badge" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1">
                        <label>Hide Badge</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment><![CDATA[You may hide the badge only if you include the reCAPTCHA branding visibly in the user flow (see the badge text below).]]></comment>
                    </field>
                    <field id="hide_badge_text" translate="label" type="textarea" sortOrder="40" showInDefault="1" showInWebsite="1">
                        <label>Badge Text</label>
                        <depends><field id="hide_badge">1</field></depends>
                    </field>
                </group>

                <group id="recaptcha_v2_checkbox" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Google reCAPTCHA v2 (Checkbox)</label>
                    <field id="site_key" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1">
                        <label>Site Key</label>
                    </field>
                    <field id="secret_key" translate="label" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1">
                        <label>Secret Key</label>
                        <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    </field>
                    <field id="theme" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1">
                        <label>Theme</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\Recaptcha\Theme</source_model>
                    </field>
                    <field id="size" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1">
                        <label>Size</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\Recaptcha\V2Size</source_model>
                    </field>
                </group>

                <group id="recaptcha_v2_invisible" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Google reCAPTCHA v2 (Invisible)</label>
                    <field id="site_key" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1">
                        <label>Site Key</label>
                    </field>
                    <field id="secret_key" translate="label" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1">
                        <label>Secret Key</label>
                        <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    </field>
                </group>

                <group id="recaptcha_enterprise" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Google reCAPTCHA Enterprise</label>
                    <field id="site_key" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1">
                        <label>Site Key</label>
                    </field>
                    <field id="secret_key" translate="label comment" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1">
                        <label>API Key</label>
                        <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                        <comment>Google Cloud API key with reCAPTCHA Enterprise API access.</comment>
                    </field>
                    <field id="project_id" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1">
                        <label>Project ID</label>
                        <comment>Google Cloud project ID hosting the Enterprise key.</comment>
                    </field>
                </group>

                <group id="turnstile" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Cloudflare Turnstile</label>
                    <field id="site_key" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1">
                        <label>Site Key</label>
                    </field>
                    <field id="secret_key" translate="label" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1">
                        <label>Secret Key</label>
                        <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    </field>
                    <field id="widget_size" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1">
                        <label>Widget Size</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\Turnstile\WidgetSize</source_model>
                    </field>
                    <field id="widget_appearance" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1">
                        <label>Widget Appearance</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\Turnstile\WidgetAppearance</source_model>
                    </field>
                </group>
            </group>

            <!-- ========================== Form Protection ========================= -->
            <group id="form_protection" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Form Protection</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Form Protection</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <group id="frontend" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Storefront Forms</label>
                    <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Enable Storefront Form Protection</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="*/enabled">1</field></depends>
                    </field>
                    <field id="enabled_customer_login" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Customer Login</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_customer_login" translate="label comment" type="select" sortOrder="25" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Customer Login — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <comment>Only applies to reCAPTCHA v3 / Enterprise.</comment>
                        <depends><field id="enabled_customer_login">1</field></depends>
                    </field>
                    <field id="enabled_customer_create" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Customer Registration</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_customer_create" translate="label" type="select" sortOrder="35" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Customer Registration — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_customer_create">1</field></depends>
                    </field>
                    <field id="enabled_customer_forgot" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Forgot Password</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_customer_forgot" translate="label" type="select" sortOrder="45" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Forgot Password — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_customer_forgot">1</field></depends>
                    </field>
                    <field id="enabled_contact" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Contact Form</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_contact" translate="label" type="select" sortOrder="55" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Contact Form — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_contact">1</field></depends>
                    </field>
                    <field id="enabled_newsletter" translate="label" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Newsletter Subscription</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_newsletter" translate="label" type="select" sortOrder="65" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Newsletter — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_newsletter">1</field></depends>
                    </field>
                    <field id="enabled_send_friend" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Send to Friend</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_send_friend" translate="label" type="select" sortOrder="75" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Send to Friend — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_send_friend">1</field></depends>
                    </field>
                    <field id="enabled_product_review" translate="label" type="select" sortOrder="80" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Product Review</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_product_review" translate="label" type="select" sortOrder="85" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Product Review — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_product_review">1</field></depends>
                    </field>
                    <field id="enabled_customer_edit" translate="label" type="select" sortOrder="90" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Customer Account Edit</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_customer_edit" translate="label" type="select" sortOrder="95" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Customer Account Edit — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_customer_edit">1</field></depends>
                    </field>
                    <field id="enabled_wishlist" translate="label" type="select" sortOrder="100" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Share Wishlist</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_wishlist" translate="label" type="select" sortOrder="105" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Share Wishlist — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_wishlist">1</field></depends>
                    </field>
                    <field id="enabled_coupon_code" translate="label comment" type="select" sortOrder="110" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Apply Coupon Code</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment>Protects both the cart coupon form and the checkout coupon WebAPI.</comment>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_coupon_code" translate="label" type="select" sortOrder="115" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Apply Coupon Code — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_coupon_code">1</field></depends>
                    </field>
                    <field id="enabled_place_order" translate="label comment" type="select" sortOrder="120" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Place Order (checkout)</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment>Validates the place-order WebAPI/GraphQL call via the X-Captcha-Token header.</comment>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_place_order" translate="label" type="select" sortOrder="125" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Place Order — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_place_order">1</field></depends>
                    </field>
                    <field id="enabled_store_pickup" translate="label" type="select" sortOrder="130" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Place Order (in-store pickup)</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_store_pickup" translate="label" type="select" sortOrder="135" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>In-store Pickup — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_store_pickup">1</field></depends>
                    </field>
                    <field id="enabled_paypal_payflowpro" translate="label" type="select" sortOrder="140" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>PayPal Payflow Pro</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_paypal_payflowpro" translate="label" type="select" sortOrder="145" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>PayPal Payflow Pro — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_paypal_payflowpro">1</field></depends>
                    </field>
                    <field id="enabled_resend_confirmation_email" translate="label" type="select" sortOrder="150" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Resend Confirmation Email</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_resend_confirmation_email" translate="label" type="select" sortOrder="155" showInDefault="1" showInWebsite="1" canRestore="1">
                        <label>Resend Confirmation Email — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_resend_confirmation_email">1</field></depends>
                    </field>
                </group>
                <group id="backend" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Admin Forms</label>
                    <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                        <label>Enable Admin Form Protection</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="*/enabled">1</field></depends>
                    </field>
                    <field id="enabled_login" translate="label" type="select" sortOrder="20" showInDefault="1" canRestore="1">
                        <label>Admin Login</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_login" translate="label" type="select" sortOrder="25" showInDefault="1" canRestore="1">
                        <label>Admin Login — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_login">1</field></depends>
                    </field>
                    <field id="enabled_forgot" translate="label" type="select" sortOrder="30" showInDefault="1" canRestore="1">
                        <label>Admin Forgot Password</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <depends><field id="enabled">1</field></depends>
                    </field>
                    <field id="score_threshold_forgot" translate="label" type="select" sortOrder="35" showInDefault="1" canRestore="1">
                        <label>Admin Forgot Password — Score Threshold</label>
                        <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ScoreThreshold</source_model>
                        <depends><field id="enabled_forgot">1</field></depends>
                    </field>
                </group>
            </group>

            <!-- ========================== Route Protection ======================== -->
            <group id="route_protection" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Route Protection (site-wide gate)</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Route Protection</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Show a full-page captcha challenge for requests matching the rules below.</comment>
                </field>
                <field id="provider_override" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Route Gate Provider</label>
                    <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\ProviderWithDefault</source_model>
                    <comment>Use a different provider for the challenge page than the active form provider.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="fallback_enabled" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Fallback Provider</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Reveal a second provider on the challenge page (e.g. reCAPTCHA when Turnstile is unreachable).</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="fallback_provider" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fallback Provider</label>
                    <source_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Source\Provider</source_model>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="fallback_enabled">1</field>
                    </depends>
                </field>
                <field id="fallback_delay" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Fallback Delay (seconds)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>How long the challenge waits before revealing the fallback widget. Default: 15</comment>
                    <depends>
                        <field id="enabled">1</field>
                        <field id="fallback_enabled">1</field>
                    </depends>
                </field>
                <field id="cookie_lifetime" translate="label comment" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Verified Cookie Lifetime (seconds)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>How long a verified visitor stays unchallenged. Default: 14400 (4 hours)</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="rules" translate="label comment" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Protection Rules</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\ProtectionRules</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                    <comment><![CDATA[Cloudflare-style filter expression. Each row is one condition — Field / Operator / Value — joined to the previous by AND / OR (AND binds tighter than OR). The challenge fires when the expression is true for the request. Regex operators take bare patterns without delimiters or quotes (e.g. <code>^catalog_.*</code>); delimited PCRE with modifiers (e.g. <code>~^/checkout~i</code>) also works. The <code>Blocked by robots.txt</code> field resolves to 1 when the requested URL is disallowed by this website's robots.txt (physical <code>pub/robots.txt</code>, or the Search Engine Robots custom instructions). Combine it with <code>Is AJAX Request</code> so background calls (customer sections, minicart, add-to-cart) stay unchallenged — e.g. <code>robots_txt_blocked eq 1 and is_ajax eq 0</code> — and use <code>Is 404 (No-Route) Page</code> to challenge URL-probing bots.]]></comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="layered_nav_ignored_params" translate="label comment" type="text" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ignored Filter Params</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\RouteParamsTagList</frontend_model>
                    <backend_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Backend\RouteParamsTagList</backend_model>
                    <comment>URL params that do NOT count toward "Active Param Count". Type a param name and press Enter.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="excluded_ips" translate="label comment" type="text" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded IPs</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\ExcludedIpsTagList</frontend_model>
                    <backend_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Backend\RouteParamsTagList</backend_model>
                    <comment>Client IPs that bypass the challenge. Type an IP and press Enter.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="excluded_user_agents" translate="label comment" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded User Agents</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\ExcludedUserAgentsTagList</frontend_model>
                    <backend_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Backend\RouteParamsTagList</backend_model>
                    <comment>User-agent substrings (trusted crawlers) that bypass the challenge. Type a substring and press Enter.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="excluded_paths" translate="label comment" type="text" sortOrder="105" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded Paths (Never Challenged)</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\RoutePathsTagList</frontend_model>
                    <backend_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Backend\RouteParamsTagList</backend_model>
                    <comment><![CDATA[Requests whose path matches any pattern bypass the challenge regardless of the rules — robots.txt-style patterns (prefix match, <code>*</code> wildcard, trailing <code>$</code> anchor). Pre-filled with Magento's background endpoints (customer sections, minicart, add-to-cart, …) so broad rules such as <code>robots_txt_blocked eq 1</code> cannot break them. Type a path and press Enter.]]></comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="ajax_marker_params" translate="label comment" type="text" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>AJAX Marker Params</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\RouteParamsTagList</frontend_model>
                    <backend_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Backend\RouteParamsTagList</backend_model>
                    <comment>Params stripped from the post-verify URL. Type a param name and press Enter.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="background_ajax_marker_params" translate="label comment" type="text" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Background AJAX Marker Params</label>
                    <frontend_model>Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\RouteParamsTagList</frontend_model>
                    <backend_model>Hryvinskyi\InvisibleCaptcha\Model\Config\Backend\RouteParamsTagList</backend_model>
                    <comment>Params marking a background preload — skip post-verify navigation. Type a param name and press Enter.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="filter_anchor_selector" translate="label comment" type="text" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Filter Anchor CSS Selector</label>
                    <comment>CSS selector for the layered-nav link captured before challenge. Leave blank to disable.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>
                <field id="filter_param_pattern" translate="label comment" type="text" sortOrder="140" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Filter Param Regex</label>
                    <comment>JS regex (no delimiters) matched against AJAX query-param keys; capture group 1 is the attribute name.</comment>
                    <depends><field id="enabled">1</field></depends>
                </field>

                <!-- Nested sub-group → paths hryvinskyi_invisible_captcha/route_protection/appearance/<field> -->
                <group id="appearance" translate="label comment" type="text" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Challenge Page Appearance</label>
                    <comment>Accent palette for the challenge page. Use a hex value (e.g. #2f6bd8) or a CSS color function such as rgba().</comment>
                    <field id="primary_color" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Primary Color</label>
                        <comment>Spinner, progress bar, buttons, links and the shield glyph. Default: #2f6bd8</comment>
                    </field>
                    <field id="primary_color_deep" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Primary Color (Deep)</label>
                        <comment>Darker shade used for hover / active states. Default: #2557b6</comment>
                    </field>
                    <field id="primary_color_soft" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                        <label>Primary Color (Soft)</label>
                        <comment>Translucent tint used for the checkbox pulse/glow. Use an rgba() value. Default: rgba(47,107,216,0.12)</comment>
                    </field>
                </group>
            </group>

            <!-- ============================== Advanced ============================ -->
            <group id="advanced" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Advanced</label>
                <field id="http_timeout" translate="label comment" type="text" sortOrder="10" showInDefault="1">
                    <label>Verification HTTP Timeout (seconds)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Wall-clock budget for an outbound siteverify/assessment request. Default: 2.0</comment>
                </field>
            </group>
        </section>
    </system>
</config>
