<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- =================== Route-gate verify endpoint router =================== -->
    <type name="Magento\Framework\App\RouterList">
        <arguments>
            <argument name="routerList" xsi:type="array">
                <item name="hryvinskyi_invisible_captcha_verification" xsi:type="array">
                    <item name="class" xsi:type="string">Hryvinskyi\InvisibleCaptcha\Controller\Router\VerificationRouter</item>
                    <item name="disable" xsi:type="boolean">false</item>
                    <item name="sortOrder" xsi:type="string">5</item>
                </item>
            </argument>
        </arguments>
    </type>

    <type name="Hryvinskyi\InvisibleCaptcha\Controller\Router\Verify">
        <arguments>
            <argument name="logger" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Logger</argument>
        </arguments>
    </type>
    <type name="Hryvinskyi\InvisibleCaptcha\Observer\RouteGate">
        <arguments>
            <argument name="logger" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Logger</argument>
        </arguments>
    </type>

    <!-- ============================== Block hooks ============================= -->
    <type name="Magento\Customer\Block\Account\AuthenticationPopup">
        <plugin sortOrder="1" name="Hryvinskyi_InvisibleCaptcha::authentication_popup"
                type="Hryvinskyi\InvisibleCaptcha\Plugin\Block\Account\AuthenticationPopupPlugin"/>
    </type>
    <type name="Magento\Checkout\Block\Onepage">
        <arguments>
            <argument name="layoutProcessors" xsi:type="array">
                <item name="invisibleCaptchaLayoutProcessor" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Block\Checkout\LayoutProcessor</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Contact\Block\ContactForm">
        <plugin name="Hryvinskyi_InvisibleCaptcha::add_form_additional_info_if_missing"
                type="Hryvinskyi\InvisibleCaptcha\Plugin\Block\ContactForm\AddFormAdditionalInfoIfMissing"/>
    </type>
    <type name="Hryvinskyi\InvisibleCaptcha\Plugin\Block\ContactForm\AddFormAdditionalInfoIfMissing">
        <arguments>
            <argument name="contactEnablement" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Enablement\Form\Contact</argument>
            <argument name="logger" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Logger</argument>
        </arguments>
    </type>

    <!-- ===================== Redirect URL providers (forms) =================== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Form\CustomerForgot"
                 type="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Simple">
        <arguments>
            <argument name="urlPath" xsi:type="string">*/*/forgotpassword</argument>
            <argument name="urlParams" xsi:type="array"><item name="_secure" xsi:type="boolean">true</item></argument>
        </arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Form\CustomerCreate"
                 type="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Simple">
        <arguments>
            <argument name="urlPath" xsi:type="string">*/*/create</argument>
            <argument name="urlParams" xsi:type="array"><item name="_secure" xsi:type="boolean">true</item></argument>
        </arguments>
    </virtualType>
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Form\Contact"
                 type="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Simple">
        <arguments>
            <argument name="urlPath" xsi:type="string">contact/index/index</argument>
        </arguments>
    </virtualType>

    <!-- ========================= Failure strategies (forms) ================== -->
    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Form\Login"
                 type="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Redirect">
        <arguments>
            <argument name="redirectUrlProvider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\BeforeAuthUrl</argument>
        </arguments>
