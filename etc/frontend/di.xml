    <virtualType name="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Form\CustomerForgot"
                 type="Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\Redirect">
        <arguments>
            <argument name="redirectUrlProvider" xsi:type="object">Hryvinskyi\InvisibleCaptcha\Model\Strategy\Failure\RedirectUrl\Form\CustomerForgot</argument>
