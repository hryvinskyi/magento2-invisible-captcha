{
    "name": "hryvinskyi/magento2-invisible-captcha",
    "description": "Magento 2 multi-provider invisible captcha & bot protection (Google reCAPTCHA v2/v3/Enterprise and Cloudflare Turnstile) for form-level and route-level protection",
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0||~8.5.0",
        "symfony/http-client": "^5 || ^6 || ^7 || ^8",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "nyholm/psr7": "^1.5",
        "magento/framework": "*",
        "magento/module-store": "*",
        "magento/module-config": "*",
        "magento/module-customer": "*",
        "magento/module-checkout": "*",
        "magento/module-newsletter": "*",
        "magento/module-contact": "*",
        "magento/module-review": "*",
        "magento/module-send-friend": "*",
        "magento/module-catalog": "*",
        "magento/module-catalog-search": "*",
        "magento/module-layered-navigation": "*",
        "magento/module-wishlist": "*",
        "magento/module-paypal": "*",
        "magento/module-sales-rule": "*",
        "magento/module-quote": "*",
        "magento/module-webapi": "*",
        "magento/module-graph-ql": "*",
        "magento/module-backend": "*",
        "magento/module-url-rewrite": "*",
        "magento/module-cms": "*",
        "hryvinskyi/magento2-base": "^2.1",
        "hryvinskyi/magento2-theme-assets": "^1.0",
        "hryvinskyi/magento2-configuration-fields": "^1.0.11"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "type": "magento2-module",
    "version": "3.2.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Volodymyr Hryvinskyi",
            "email": "volodymyr@hryvinskyi.com",
            "homepage": "https://hryvinskyi.com"
        }
    ],
    "autoload": {
        "files": [ "registration.php" ],
        "psr-4": {
            "Hryvinskyi\\InvisibleCaptcha\\": ""
        }
    },
    "config": {
        "secure-http": false
    },
    "repositories": [
        {
            "type": "composer",
            "url": "http://repo.magento.com/"
        }
    ]
}
