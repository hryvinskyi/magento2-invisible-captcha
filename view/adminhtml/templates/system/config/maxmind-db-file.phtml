/** @var \Hryvinskyi\InvisibleCaptcha\Block\Adminhtml\System\Config\Form\Field\MaxmindDbFile $block */
/** @var \Magento\Framework\Escaper $escaper */

$inputName = $block->getInputName();
$inputId = $block->getInputId();
$currentFile = $block->getCurrentFile();
$disabled = $block->isDisabled();
$extensionLoaded = $block->isMaxmindExtensionLoaded();
?>
<div class="hic-mmdb">
    <style>
        .hic-mmdb { max-width: 640px; font-size: 1.3rem; }
        .hic-mmdb-input { display: block; }
        .hic-mmdb-card {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-top: 1rem;
            padding: 1rem 1.2rem;
            border: 1px solid #d6d6d6;
            border-radius: 4px;
            background: #fafafa;
        }
        .hic-mmdb-glyph {
            flex: 0 0 auto;
            width: 28px;
            height: 28px;
            color: #6f6f6f;
        }
        .hic-mmdb-glyph svg { display: block; width: 100%; height: 100%; }
        .hic-mmdb-name { flex: 1 1 auto; min-width: 0; color: #303030; word-break: break-all; }
        .hic-mmdb-name strong { font-weight: 600; }
        .hic-mmdb-delete {
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            color: #514943;
            white-space: nowrap;
            cursor: pointer;
