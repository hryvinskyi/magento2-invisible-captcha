<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Hryvinskyi\InvisibleCaptcha\Block\Captcha" name="invisible.captcha.coupon_code"
                   template="Hryvinskyi_InvisibleCaptcha::captcha_targeted.phtml"
                   ifconfig="hryvinskyi_invisible_captcha/form_protection/frontend/enabled_coupon_code">
                <arguments>
                    <argument name="target_form" xsi:type="string">#discount-coupon-form</argument>
                    <argument name="jsLayout" xsi:type="array">
                        <item name="components" xsi:type="array">
                            <item name="invisible-captcha" xsi:type="array">
                                <item name="component" xsi:type="string">Hryvinskyi_InvisibleCaptcha/js/invisible-captcha</item>
                                <item name="action" xsi:type="string">coupon_code</item>
                                <item name="captchaId" xsi:type="string">coupon_code</item>
                            </item>
                        </item>
                    </argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
