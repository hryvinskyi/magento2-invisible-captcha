<div class="field-recaptcha" data-hryvinskyi-captcha="default"
     id="<?= $block->escapeHtmlAttr($block->getWidgetId()) ?>"
     data-bind="scope:'<?= $block->escapeHtmlAttr($block->getScope()) ?>'">
    <!-- ko template: getTemplate() --><!-- /ko -->
    <?php if ($block->isHideBadge()): ?>
        <?= $secureRenderer->renderTag('style', [], '.grecaptcha-badge {display:none;}', false) ?>
        <div class="hint"><?= /* @noEscape */ $block->getHideBadgeText() ?></div>
    <?php endif; ?>
</div>
<?php if ($block->isDisabledSubmitForm() || $block->isLazyLoad()): ?>
    <?php
    /*
     * Disable the submit button until the captcha client is ready, with CSS + a
     * tiny parse-time script (no server-side HTML rewriting). The script adds the
     * `hryvinskyi-captcha-disabled-submit` class to the surrounding form; the CSS
     * in view/base/web/css/source/_module.less makes the submit button
     * unclickable while that class is present. form-manager.js removes the class
     * once the captcha is ready. The marker div is inside the form, so closest()
     * resolves synchronously at parse time.
     */
    $scriptContent = <<<JS
(() => {
    const field = document.getElementById('{$block->getWidgetId()}');
    const form = field ? field.closest('form') : null;
    if (form !== null) {
        form.classList.add('hryvinskyi-captcha-disabled-submit');
    }
})();
JS;
    echo $secureRenderer->renderTag(
        'script',
        [
            'data-pagespeed-ignore-merge' => null,
            'data-ignore-extreme-lazy-load' => null,
        ],
        $scriptContent,
        false
    );
    ?>
<?php endif; ?>
<script type="text/x-magento-init">
{
    "#<?= $block->escapeHtmlAttr($block->getWidgetId()) ?>": {
        "Magento_Ui/js/core/app": <?= /* @noEscape */ $block->getJsLayout() ?>
    }
}
</script>
